{
  "name": "iframe-element-tracker",
  "version": "1.0.0",
  "description": "A SDK for tracking DOM elements inside iframes and synchronizing their position, size, and style information to the host page",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tracker": {
      "types": "./dist/tracker/index.d.ts",
      "import": "./dist/tracker.js",
      "require": "./dist/tracker.cjs"
    },
    "./receiver": {
      "types": "./dist/receiver/index.d.ts",
      "import": "./dist/receiver.js",
      "require": "./dist/receiver.cjs"
    },
    "./overlay-positioner": {
      "types": "./dist/overlay-positioner/index.d.ts",
      "import": "./dist/overlay-positioner.js",
      "require": "./dist/overlay-positioner.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "iframe",
    "element-tracker",
    "overlay",
    "postmessage",
    "dom",
    "cross-iframe"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:perf": "playwright test tests/e2e/performance.spec.ts",
    "test:publish": "npm run lint && npx tsc --noEmit && npm test && npm run test:e2e && npm run build",
    "release": "release-it",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.58.2",
    "@release-it/conventional-changelog": "^9.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "release-it": "^17.11.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.0.12",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  }
}
